---
import { services } from '../../../data/portfolio';
import type { Service } from '../../../data/portfolio';
import SectionIntro from '../../ui/SectionIntro.astro';

const featuredServices = services.filter((service) => service.featured).length;

const iconPaths = {
	monitor: 'M4 6.5A2.5 2.5 0 0 1 6.5 4h11A2.5 2.5 0 0 1 20 6.5v7a2.5 2.5 0 0 1-2.5 2.5h-4.25L14 20h-4l.75-4H6.5A2.5 2.5 0 0 1 4 13.5v-7Z',
	server: 'M5 6.5C5 5.12 8.13 4 12 4s7 1.12 7 2.5S15.87 9 12 9 5 7.88 5 6.5Zm0 5C5 10.12 8.13 9 12 9s7 1.12 7 2.5-3.13 2.5-7 2.5-7-1.12-7-2.5Zm0 5C5 15.12 8.13 14 12 14s7 1.12 7 2.5S15.87 19 12 19s-7-1.12-7-2.5ZM8 6.5h.01M8 11.5h.01M8 16.5h.01',
	brand: 'M12 4 14.6 9.2 20 10l-4 3.9.94 5.6L12 16.9 7.06 19.5 8 13.9 4 10l5.4-.8L12 4Z',
	custom: 'M12 5v14M5 12h14',
} as const;
---

<section id="servicios" class="py-10 sm:py-12 lg:py-16">
	<div class="rounded-4xl border border-ink/8 bg-surface/88 p-5 shadow-sm shadow-black/5 sm:p-8">
		<div class="mb-6 flex flex-col gap-4 sm:mb-8 sm:gap-5 lg:flex-row lg:items-end lg:justify-between">
			<div class="lg:max-w-3xl">
				<SectionIntro
					kicker="Servicios"
					title="Servicios enfocados en presencia y producto"
						description="Cuatro enfoques según lo que necesitas ahora: desde lanzar tu primera web hasta refinar un producto que ya existe."
				/>
			</div>
			<div class="flex flex-wrap items-center gap-2.5 sm:gap-3 lg:pb-8">
				<span class="rounded-full border border-gold-main/20 bg-gold-main/10 px-3 py-1.5 text-[0.68rem] font-medium uppercase tracking-[0.14em] text-violet-deep sm:px-4 sm:py-2 sm:text-xs sm:tracking-[0.22em]">
					{services.length} servicios
				</span>
				<span class="rounded-full border border-violet-main/20 bg-violet-soft/35 px-3 py-1.5 text-[0.68rem] font-medium uppercase tracking-[0.14em] text-violet-deep sm:px-4 sm:py-2 sm:text-xs sm:tracking-[0.22em]">
					{featuredServices} destacados
				</span>
			</div>
		</div>

		<div class="grid gap-3.5 sm:grid-cols-2 sm:gap-4 lg:grid-cols-12">
			{services.map((service: Service, index: number) => (
				(() => {
					const whatsappMessage = `${service.inquiry} [Servicio: ${service.title}]`;

					return (
				<article
					class:list={[
						'flex h-full flex-col rounded-3xl border p-4 transition sm:p-5',
						index === 0 ? 'sm:col-span-2 lg:col-span-7' : index === 1 ? 'sm:col-span-2 lg:col-span-5' : 'lg:col-span-6',
						service.featured
							? 'border-gold-main/20 bg-linear-to-br from-gold-main/12 via-surface/95 to-violet-soft/18 shadow-lg shadow-black/8'
							: 'border-ink/8 bg-paper/88 shadow-sm shadow-black/5',
					]}
				>
					<div class="flex items-start justify-between gap-4">
						<div class="flex h-12 w-12 items-center justify-center rounded-2xl border border-gold-main/20 bg-gold-main/10 text-gold-soft">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="h-6 w-6">
								<path d={iconPaths[service.icon]} stroke-linecap="round" stroke-linejoin="round"></path>
							</svg>
						</div>
						{service.featured ? (
							<span class="rounded-full border border-gold-main/25 bg-gold-main/10 px-3 py-1 text-xs uppercase tracking-[0.16em] text-violet-deep">
								Más solicitado
							</span>
						) : (
							<span class="rounded-full border border-ink/10 bg-white/70 px-3 py-1 text-xs uppercase tracking-[0.16em] text-ink/60">
								Servicio
							</span>
						)}
					</div>

					<div class="mb-3.5 mt-4 h-2 w-14 rounded-full bg-linear-to-r from-gold-main to-violet-soft"></div>
					<h3 class="text-lg font-semibold text-ink sm:text-xl">{service.title}</h3>
					<p class="mt-2.5 text-sm leading-6 text-ink/70 sm:mt-3 sm:text-base sm:leading-7">{service.description}</p>

					<a
						href={`https://wa.me/34628230716?text=${encodeURIComponent(whatsappMessage)}`}
						target="_blank"
						rel="noreferrer"
						class="mt-4 inline-flex w-full justify-center rounded-full border border-ink/10 bg-paper px-4 py-2 text-sm font-semibold text-ink transition hover:border-gold-main/30 hover:bg-surface hover:text-violet-deep sm:mt-5 sm:w-auto"
					>
						{service.cta}
					</a>
				</article>
					);
				})()
			))}
		</div>
	</div>
</section>