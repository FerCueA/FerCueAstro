---
import { certificates } from '../../../data/portfolio';
import type { Certificate as PortfolioCertificate } from '../../../data/portfolio';
import SectionIntro from '../../ui/SectionIntro.astro';

const certificateCategories = [
	'Todos',
	...new Set(certificates.map((certificate: PortfolioCertificate) => certificate.category)),
];

const categoryCount = certificateCategories.length - 1;
---

<section id="certificados" class="py-10 lg:py-12">
	<div class="rounded-4xl border border-ink/8 bg-surface/88 p-5 shadow-sm shadow-black/5 sm:p-8">
		<div class="mb-6 flex flex-col gap-4 sm:mb-8 sm:gap-5 lg:flex-row lg:items-end lg:justify-between">
			<div class="lg:max-w-3xl">
				<SectionIntro
					kicker="Certificados"
					title="Credenciales y formación"
						description="Formación que respalda cada área de trabajo: frontend, JavaScript, backend con Java y Spring, bases de datos y herramientas de desarrollo."
				/>
				<div class="-mt-1.5 flex flex-wrap gap-2" data-certificate-filters>
					{certificateCategories.map((category, index) => (
						<button
							type="button"
							data-filter={category}
							class:list={[
								'rounded-full border px-3.5 py-1.5 text-sm transition sm:px-4 sm:py-2',
								index === 0
									? 'border-gold-main/30 bg-gold-main/10 text-violet-deep'
									: 'border-ink/8 bg-paper/85 text-ink/65 hover:border-gold-main/20 hover:text-violet-deep',
							]}
						>
							{category}
						</button>
					))}
				</div>
			</div>

			<div class="flex flex-wrap items-center gap-2.5 sm:gap-3 lg:pb-8">
				<span class="rounded-full border border-gold-main/20 bg-gold-main/10 px-3 py-1.5 text-[0.68rem] font-medium uppercase tracking-[0.14em] text-violet-deep sm:px-4 sm:py-2 sm:text-xs sm:tracking-[0.22em]">
					{certificates.length} certificados
				</span>
				<span class="rounded-full border border-violet-main/20 bg-violet-soft/35 px-3 py-1.5 text-[0.68rem] font-medium uppercase tracking-[0.14em] text-violet-deep sm:px-4 sm:py-2 sm:text-xs sm:tracking-[0.22em]">
					{categoryCount} categorías
				</span>
			</div>
		</div>

		{certificates.length > 0 ? (
			<div class="flex snap-x snap-mandatory gap-3 overflow-x-auto pb-2 sm:grid sm:snap-none sm:gap-4 sm:overflow-visible sm:pb-0 sm:grid-cols-2 xl:grid-cols-3" data-certificate-grid>
				{certificates.map((certificate: PortfolioCertificate) => (
					<article
						class="flex flex-col w-[78%] shrink-0 snap-start rounded-[1.35rem] border border-gold-main/15 bg-linear-to-br from-surface to-paper p-3.5 shadow-sm shadow-black/5 sm:h-full sm:w-auto sm:shrink sm:rounded-[1.6rem] sm:p-5"
						data-certificate-card
						data-category={certificate.category}
					>
						<div class="flex items-center justify-between gap-3">
							<p class="text-[0.66rem] uppercase tracking-[0.14em] text-violet-deep sm:text-xs sm:tracking-[0.22em]">{certificate.category}</p>
							<div class="rounded-full border border-ink/8 bg-paper px-3 py-1 text-xs text-ink/55">Credencial</div>
						</div>
						<h3 class="mt-3 text-base font-semibold text-ink sm:mt-4 sm:text-xl">{certificate.title}</h3>
						<p class="mt-2 flex-grow text-xs leading-5 text-ink/68 sm:mt-3 sm:text-sm sm:leading-6">
							{certificate.issuer ?? 'Certificado en formato PDF listo para abrir desde la web.'}
						</p>
						<a
							href={encodeURI(certificate.href)}
							target="_blank"
							rel="noreferrer"
							class="mt-3 inline-flex w-full justify-center rounded-full bg-gold-main px-3.5 py-2 text-sm font-semibold text-ink transition hover:bg-gold-soft sm:mt-5 sm:w-auto sm:px-4"
						>
							Abrir certificado
						</a>
					</article>
				))}
			</div>
		) : (
			<div class="rounded-4xl border border-ink/8 bg-surface p-6 text-ink/70">
				No se encontraron PDFs en la carpeta publica de certificados.
			</div>
		)}
	</div>
</section>

<script>
	const filterGroups = document.querySelectorAll('[data-certificate-filters]');

	filterGroups.forEach((group) => {
		const section = group.closest('section');
		const cards = Array.from(section?.querySelectorAll('[data-certificate-card]') ?? []);
		const buttons = Array.from(group.querySelectorAll('[data-filter]'));
		const grid = section?.querySelector('[data-certificate-grid]');

		buttons.forEach((button) => {
			button.addEventListener('click', () => {
				const selectedCategory = button.getAttribute('data-filter') ?? 'Todos';

				buttons.forEach((currentButton) => {
					const isActive = currentButton === button;
					currentButton.className = isActive
						? 'rounded-full border border-gold-main/30 bg-gold-main/10 px-3.5 py-1.5 text-sm text-violet-deep transition sm:px-4 sm:py-2'
						: 'rounded-full border border-ink/8 bg-paper/85 px-3.5 py-1.5 text-sm text-ink/65 transition hover:border-gold-main/20 hover:text-violet-deep sm:px-4 sm:py-2';
				});

				cards.forEach((card) => {
					const matches = selectedCategory === 'Todos' || card.getAttribute('data-category') === selectedCategory;
					card.toggleAttribute('hidden', !matches);
				});

				if (grid instanceof HTMLElement) {
					grid.scrollTo({ left: 0, behavior: 'smooth' });
				}
			});
		});
	});
</script>